---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign pages_for_sitemap = site.pages | sort: "url" %}
{% for page in pages_for_sitemap %}
  {% unless page.sitemap == false or page.name == "404.html" or page.url == "/" or page.url == "/sitemap.xml" or page.url == "/robots.txt" %}
    {% if page.url %}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
  </url>
    {% endif %}
  {% endunless %}
{% endfor %}
</urlset>
